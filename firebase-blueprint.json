{
  "entities": {
    "Car": {
      "title": "Car",
      "description": "A car for sale",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the car" },
        "price": { "type": "number", "description": "The price of the car" },
        "description": { "type": "string", "description": "The description of the car" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "The images of the car" },
        "year": { "type": "number", "description": "The year of the car" },
        "mileage": { "type": "number", "description": "The mileage of the car" },
        "fuel": { "type": "string", "description": "The fuel type of the car" },
        "transmission": { "type": "string", "description": "The transmission of the car" },
        "extras": { "type": "array", "items": { "type": "string" }, "description": "The extras of the car" },
        "featured": { "type": "boolean", "description": "Whether the car is featured" },
        "urgencyLabel": { "type": "string", "description": "The urgency label of the car" },
        "brand": { "type": "string", "description": "The brand of the car" },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation date of the car" }
      },
      "required": ["title", "price", "description", "images", "year", "brand"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A lead for a car",
      "type": "object",
      "properties": {
        "clientName": { "type": "string", "description": "The name of the client" },
        "phone": { "type": "string", "description": "The phone number of the client" },
        "email": { "type": "string", "description": "The email of the client" },
        "budget": { "type": "number", "description": "The budget of the client" },
        "carId": { "type": "string", "description": "The ID of the car" },
        "carTitle": { "type": "string", "description": "The title of the car" },
        "message": { "type": "string", "description": "The message of the client" },
        "status": { "type": "string", "description": "The status of the lead" },
        "marketerId": { "type": "string", "description": "The ID of the marketer" },
        "marketerName": { "type": "string", "description": "The name of the marketer" },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation date of the lead" }
      },
      "required": ["clientName", "phone", "budget", "carId", "status"]
    },
    "Marketer": {
      "title": "Marketer",
      "description": "A marketer for the platform",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "The full name of the marketer" },
        "phone": { "type": "string", "description": "The phone number of the marketer" },
        "email": { "type": "string", "description": "The email of the marketer" },
        "cashNumber": { "type": "string", "description": "The cash number of the marketer" },
        "totalLeads": { "type": "number", "description": "The total number of leads" },
        "confirmedDeals": { "type": "number", "description": "The number of confirmed deals" },
        "paidCommissions": { "type": "number", "description": "The amount of paid commissions" },
        "remainingCommissions": { "type": "number", "description": "The amount of remaining commissions" },
        "targetProgress": { "type": "number", "description": "The target progress of the marketer" },
        "role": { "type": "string", "description": "The role of the marketer" },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation date of the marketer" }
      },
      "required": ["fullName", "phone", "email", "role"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user" },
        "message": { "type": "string", "description": "The message of the notification" },
        "read": { "type": "boolean", "description": "Whether the notification is read" },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation date of the notification" }
      },
      "required": ["userId", "message", "read", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "The settings for the platform",
      "type": "object",
      "properties": {
        "commissionRate": { "type": "number", "description": "The commission rate" },
        "targetRewards": { "type": "array", "items": { "type": "object" }, "description": "The target rewards" }
      }
    }
  },
  "firestore": {
    "cars": { "schema": "Car", "description": "The collection of cars" },
    "leads": { "schema": "Lead", "description": "The collection of leads" },
    "marketers": { "schema": "Marketer", "description": "The collection of marketers" },
    "notifications": { "schema": "Notification", "description": "The collection of notifications" },
    "settings": { "schema": "Settings", "description": "The settings for the platform" }
  }
}
